{
  "name": "vait-homepage",
  "version": "1.0.0",
  "description": "VAIT Homepage",
  "type": "module",
  "scripts": {
    "prepare": "pnpm run githooks:init",
    "githooks:init": "husky",
    "dev": "vite",
    "dev:cf": "DEPLOY_TO_CLOUDFLARE=true pnpm run dev",
    "build": "vite build",
    "build:cf": "DEPLOY_TO_CLOUDFLARE=true pnpm run build",
    "preview": "vite preview",
    "typecheck": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:CI": "pnpm run test && pnpm run typecheck",
    "test:preview": "vitest-preview",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix && oxfmt --write",
    "lint:fix:unsafe": "oxlint --fix-dangerously && oxfmt --write",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "ci": "oxlint && oxfmt --check",
    "deploy:cf": "wrangler deploy"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.15",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-router-devtools": "^1.167.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide": "^1.17.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-error-boundary": "^6.1.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.0",
    "@tanstack/router-cli": "^1.167.17",
    "@tanstack/router-vite-plugin": "^1.167.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "babel-plugin-react-compiler": "^1.0.0",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-prepush": "^3.0.3",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vitest-preview": "^0.0.3",
    "wrangler": "^4.98.0"
  },
  "engines": {
    "node": "^24.0.0",
    "pnpm": "^11.0.0"
  },
  "packageManager": "pnpm@11.5.2"
}
